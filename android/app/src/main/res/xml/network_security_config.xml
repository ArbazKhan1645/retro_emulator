<?xml version="1.0" encoding="utf-8"?>
<!--
    Network Security Config for RetroVerse
    - Only HTTPS connections allowed (no cleartext HTTP)
    - Archive.org and IGDB CDN explicitly trusted for ROM downloads & cover art
-->
<network-security-config>
    <base-config cleartextTrafficPermitted="false">
        <trust-anchors>
            <!-- Trust the system CA store (covers IGDB, Archive.org, etc.) -->
            <certificates src="system" />
        </trust-anchors>
    </base-config>

    <!-- Allow debug builds to use cleartext for local dev server -->
    <debug-overrides>
        <trust-anchors>
            <certificates src="system" />
            <certificates src="user" />
        </trust-anchors>
    </debug-overrides>
</network-security-config>
